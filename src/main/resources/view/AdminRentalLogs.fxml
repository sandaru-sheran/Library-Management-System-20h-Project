<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import java.net.URL?>

<AnchorPane prefHeight="650.0" prefWidth="950.0" styleClass="main-pane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sanda.librarymanagement.controller.AdminRentalLogsController">
    <stylesheets>
        <URL value="@css/style.css" />
    </stylesheets>
    <children>
        <VBox layoutX="30.0" layoutY="30.0" spacing="25.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
            <children>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="report-title" text="Global Rental Logs">
                                    <font>
                                        <Font name="Segoe UI Bold" size="24.0" />
                                    </font>
                                </Label>
                                <Label styleClass="report-subtitle" text="A complete history of all book issues, returns, and financial records." />
                            </children>
                        </VBox>
                        <VBox alignment="CENTER" prefHeight="60.0" prefWidth="200.0" styleClass="metric-box">
                            <children>
                                <Label styleClass="metric-label" text="Total Transactions" />
                                <Label fx:id="lblTotalTransactions" styleClass="metric-value-yellow" text="0">
                                    <font>
                                        <Font name="System Bold" size="22.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <TextField fx:id="txtSearchLogs" prefHeight="45.0" promptText="Search by Rental ID, Customer ID, or Book ID..." styleClass="search-field" />

                <TableView fx:id="tblRentalLogs" styleClass="table-view" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colRentalId" prefWidth="60.0" text="RID" styleClass="table-column-center" />
                        <TableColumn fx:id="colBookId" prefWidth="80.0" text="Book ID" styleClass="table-column-center" />
                        <TableColumn fx:id="colCustId" prefWidth="80.0" text="Cust ID" styleClass="table-column-center" />
                        <TableColumn fx:id="colIssueDate" prefWidth="110.0" text="Issue Date" styleClass="table-column-center" />
                        <TableColumn fx:id="colReturnDate" prefWidth="110.0" text="Return Date" styleClass="table-column-center" />
                        <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" styleClass="table-column-center" />
                        <TableColumn fx:id="colFine" prefWidth="100.0" text="Fine (LKR)" styleClass="table-column-center" />
                        <TableColumn fx:id="colPayment" prefWidth="120.0" text="Payment" styleClass="table-column-center" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</AnchorPane>