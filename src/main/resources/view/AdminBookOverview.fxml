<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import java.net.URL?>

<AnchorPane prefHeight="650.0" prefWidth="950.0" styleClass="main-pane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sanda.librarymanagement.controller.AdminBookOverviewController">
    <stylesheets>
        <URL value="@css/style.css" />
    </stylesheets>
    <children>
        <VBox layoutX="30.0" layoutY="30.0" spacing="25.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
            <children>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="report-title" text="Global Book Inventory" />
                                <Label styleClass="report-subtitle" text="A comprehensive view of all books currently in the library system." />
                            </children>
                        </VBox>
                        <VBox alignment="CENTER" prefHeight="60.0" prefWidth="180.0" styleClass="metric-box">
                            <children>
                                <Label styleClass="metric-label" text="Total Books" />
                                <Label fx:id="lblTotalBooksCount" styleClass="metric-value-blue" text="0" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <TextField fx:id="txtSearchInventory" prefHeight="45.0" promptText="Search by Title, Author, Category or ID..." styleClass="search-field" />

                <TableView fx:id="tblInventory" styleClass="table-view" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colBookId" prefWidth="80.0" text="Book ID" styleClass="table-column-center" />
                        <TableColumn fx:id="colBookTitle" prefWidth="250.0" text="Title" styleClass="table-column-center" />
                        <TableColumn fx:id="colBookAuthor" prefWidth="180.0" text="Author" styleClass="table-column-center" />
                        <TableColumn fx:id="colBookCategory" prefWidth="150.0" text="Category" styleClass="table-column-center" />
                        <TableColumn fx:id="colBookQty" prefWidth="100.0" text="Qty in Stock" styleClass="table-column-center" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</AnchorPane>