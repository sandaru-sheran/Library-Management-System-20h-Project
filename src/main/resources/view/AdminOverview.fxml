<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import java.net.URL?>

<AnchorPane prefHeight="650.0" prefWidth="850.0" styleClass="main-pane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sanda.librarymanagement.controller.AdminOverviewController">
    <stylesheets>
        <URL value="@css/style.css" />
    </stylesheets>
    <children>
        <VBox layoutX="40.0" layoutY="30.0" spacing="20.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="30.0">
            <children>
                <VBox spacing="5.0">
                    <children>
                        <Label styleClass="dashboard-title" text="Administrator Dashboard">
                            <font>
                                <Font name="Segoe UI Bold" size="28.0" />
                            </font>
                        </Label>
                        <Label styleClass="dashboard-subtitle" text="High-level system metrics and financial overview.">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <HBox spacing="15.0">
                    <children>
                        <VBox prefHeight="110.0" prefWidth="175.0" styleClass="metric-box, metric-box-purple">
                            <children>
                                <Label styleClass="metric-label" text="Total Users" />
                                <Region VBox.vgrow="ALWAYS" />
                                <Label fx:id="lblTotalUsers" text="0" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="28.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <VBox prefHeight="110.0" prefWidth="175.0" styleClass="metric-box, metric-box-green">
                            <children>
                                <Label styleClass="metric-label" text="Paid Fines (LKR)" />
                                <Region VBox.vgrow="ALWAYS" />
                                <Label fx:id="lblTotalPaid" styleClass="metric-value-green" text="0.00">
                                    <font>
                                        <Font name="System Bold" size="28.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <VBox prefHeight="110.0" prefWidth="175.0" styleClass="metric-box, metric-box-red">
                            <children>
                                <Label styleClass="metric-label" text="Unpaid Fines (LKR)" />
                                <Region VBox.vgrow="ALWAYS" />
                                <Label fx:id="lblTotalUnpaid" styleClass="metric-value-red" text="0.00">
                                    <font>
                                        <Font name="System Bold" size="28.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <VBox prefHeight="110.0" prefWidth="175.0" styleClass="metric-box, metric-box-yellow">
                            <children>
                                <Label styleClass="metric-label" text="Unreturned Books" />
                                <Region VBox.vgrow="ALWAYS" />
                                <Label fx:id="lblUnreturned" text="0" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="28.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="fine-box">
                    <children>
                        <Label styleClass="fine-label" text="Fine Per Overdue Day (LKR):">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Label>
                        <TextField fx:id="txtFinePerDay" prefHeight="35.0" prefWidth="120.0" promptText="e.g. 15.00" styleClass="fine-textfield" />
                        <Button fx:id="btnSaveFine" onAction="#saveFineOnAction" prefHeight="35.0" prefWidth="100.0" styleClass="update-button" text="Update" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblFineUpdateStatus" textFill="#10b981">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>

                <VBox spacing="10.0" styleClass="recent-rentals-box" VBox.vgrow="ALWAYS">
                    <children>
                        <Label styleClass="recent-rentals-title" text="Recent Rental Activity">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>

                        <TableView fx:id="tblRecentRentals" prefHeight="215.0" prefWidth="684.0" styleClass="table-view" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colDate" prefWidth="201.0" text="Issue Date" styleClass="table-column-center" />
                                <TableColumn fx:id="colCustomerName" prefWidth="179.0" text="Customer Name" styleClass="table-column-center" />
                                <TableColumn fx:id="colBookTitle" prefWidth="183.0" text="Book Title" styleClass="table-column-center" />
                                <TableColumn fx:id="colStatus" prefWidth="166.0" text="Status" styleClass="table-column-center" />
                            </columns>
                        </TableView>

                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>