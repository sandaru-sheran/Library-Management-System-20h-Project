<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import java.net.URL?>

<AnchorPane prefHeight="650.0" prefWidth="840.0" styleClass="main-pane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sanda.librarymanagement.controller.DashboardController">
    <stylesheets>
        <URL value="@css/style.css" />
    </stylesheets>
    <children>
        <VBox layoutX="40.0" layoutY="30.0" spacing="30.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="30.0">
            <children>
                <VBox spacing="5.0">
                    <children>
                        <Label styleClass="dashboard-title" text="System Overview">
                            <font>
                                <Font name="Segoe UI Bold" size="28.0" />
                            </font>
                        </Label>
                        <Label styleClass="dashboard-subtitle" text="Welcome back! Here is what's happening in the library today.">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <HBox spacing="20.0">
                    <children>
                        <VBox prefHeight="120.0" prefWidth="240.0" styleClass="metric-box, metric-box-blue">
                            <children>
                                <Label styleClass="metric-label" text="Total Books" />
                                <Region VBox.vgrow="ALWAYS" />
                                <Label fx:id="lblTotalBooks" text="0" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="32.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <VBox prefHeight="120.0" prefWidth="240.0" styleClass="metric-box, metric-box-green">
                            <children>
                                <Label styleClass="metric-label" text="Registered Members" />
                                <Region VBox.vgrow="ALWAYS" />
                                <Label fx:id="lblTotalMembers" text="0" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="32.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <VBox prefHeight="120.0" prefWidth="240.0" styleClass="metric-box, metric-box-red">
                            <children>
                                <Label styleClass="metric-label" text="Overdue Books" />
                                <Region VBox.vgrow="ALWAYS" />
                                <Label fx:id="lblOverdueBooks" text="0" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="32.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox prefHeight="350.0" spacing="15.0" styleClass="recent-rentals-box" VBox.vgrow="ALWAYS">
                    <children>
                        <Label styleClass="recent-rentals-title" text="Recent Transactions">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>
                        <TableView fx:id="tblRecentTransactions" prefHeight="200.0" prefWidth="200.0" styleClass="table-view" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colTransId" prefWidth="100.0" text="ID" />
                                <TableColumn fx:id="colMemberName" prefWidth="250.0" text="Member Name" />
                                <TableColumn fx:id="colBookTitle" prefWidth="250.0" text="Book Title" />
                                <TableColumn fx:id="colDate" prefWidth="150.0" text="Date" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>