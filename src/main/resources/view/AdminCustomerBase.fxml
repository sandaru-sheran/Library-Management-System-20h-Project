<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import java.net.URL?>

<AnchorPane prefHeight="650.0" prefWidth="950.0" styleClass="main-pane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sanda.librarymanagement.controller.AdminCustomerBaseController">
    <stylesheets>
        <URL value="@css/style.css" />
    </stylesheets>
    <children>
        <VBox layoutX="30.0" layoutY="30.0" spacing="25.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
            <children>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="report-title" text="Global Customer Directory" />
                                <Label styleClass="report-subtitle" text="Comprehensive view of all library members registered by staff." />
                            </children>
                        </VBox>
                        <VBox alignment="CENTER" prefHeight="60.0" prefWidth="180.0" styleClass="metric-box">
                            <children>
                                <Label styleClass="metric-label" text="Total Members" />
                                <Label fx:id="lblTotalMembers" styleClass="metric-value-blue" text="0" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <TextField fx:id="txtSearchCustomer" prefHeight="45.0" promptText="Search by Name, Email, or Contact..." styleClass="search-field" />

                <TableView fx:id="tblCustomers" styleClass="table-view" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colCustId" prefWidth="80.0" text="Cust ID" styleClass="table-column-center" />
                        <TableColumn fx:id="colCustName" prefWidth="180.0" text="Full Name" styleClass="table-column-center" />
                        <TableColumn fx:id="colCustAddress" prefWidth="220.0" text="Address" styleClass="table-column-center" />
                        <TableColumn fx:id="colCustContact" prefWidth="130.0" text="Contact Number" styleClass="table-column-center" />
                        <TableColumn fx:id="colCustEmail" prefWidth="200.0" text="Email Address" styleClass="table-column-center" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</AnchorPane>