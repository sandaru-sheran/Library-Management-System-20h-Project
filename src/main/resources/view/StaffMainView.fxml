<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import java.net.URL?>

<BorderPane fx:id="mainPane" prefHeight="800.0" prefWidth="1200.0" styleClass="main-pane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sanda.librarymanagement.controller.StaffMainController">
    <stylesheets>
        <URL value="@css/style.css" />
    </stylesheets>
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="30.0" styleClass="top-bar" BorderPane.alignment="CENTER">
            <children>
                <Label styleClass="top-bar-label" text="Library System" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="btnClose" onAction="#closeApp" prefHeight="30.0" prefWidth="45.0" styleClass="close-button" text="✕" />
            </children>
        </HBox>
    </top>

    <left>
        <VBox styleClass="sidebar" maxWidth="260.0" minWidth="260.0" prefWidth="260.0" BorderPane.alignment="CENTER">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <VBox.margin><Insets bottom="30.0" top="10.0" /></VBox.margin>
                    <children>
                        <ImageView fitHeight="133.0" fitWidth="218.0" pickOnBounds="true" preserveRatio="true">
                            <image><Image url="@../Library.png" /></image>
                        </ImageView>
                    </children>
                </HBox>
                <Button fx:id="btnDashboard" maxWidth="Infinity" mnemonicParsing="false" prefHeight="45.0" styleClass="sidebar-button, sidebar-button-active" text="Dashboard" />
                <Button fx:id="btnBooks" maxWidth="Infinity" mnemonicParsing="false" prefHeight="45.0" styleClass="sidebar-button" text="Books" />
                <Button fx:id="btnMembers" maxWidth="Infinity" mnemonicParsing="false" prefHeight="45.0" styleClass="sidebar-button" text="Members" />
                <Button fx:id="btnBorrow" maxWidth="Infinity" mnemonicParsing="false" prefHeight="45.0" styleClass="sidebar-button" text="Borrow / Return" />
                <Region VBox.vgrow="ALWAYS" />
                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#logoutaction" prefHeight="45.0" styleClass="logout-button" text="Logout" />
            </children>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" styleClass="content-area" BorderPane.alignment="CENTER" />
    </center>
</BorderPane>