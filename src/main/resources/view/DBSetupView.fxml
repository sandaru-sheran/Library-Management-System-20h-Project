<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.text.Font?>
<?import java.net.URL?>

<AnchorPane prefHeight="616.0" prefWidth="477.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sanda.librarymanagement.controller.DBSetupController">
    <stylesheets>
        <URL value="@css/style.css" />
    </stylesheets>
    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="35.0" styleClass="top-bar" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label styleClass="top-bar-label" text="Database Configuration">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#closeApp" styleClass="close-button" text="✕" />
            </children>
        </HBox>

        <Label alignment="CENTER" layoutX="49.0" layoutY="66.0" prefHeight="72.0" prefWidth="380.0" styleClass="db-setup-title" text="DB Connection">
            <font>
                <Font size="40.0" />
            </font>
        </Label>
        <Label alignment="CENTER" layoutX="60.0" layoutY="126.0" prefWidth="358.0" styleClass="db-setup-subtitle" text="Could not connect. Please verify your credentials." />

        <TextField fx:id="txtHost" layoutX="60.0" layoutY="180.0" prefHeight="50.0" prefWidth="250.0" promptText="Host (e.g., localhost)" styleClass="text-field" text="localhost" />

        <TextField fx:id="txtPort" layoutX="325.0" layoutY="180.0" prefHeight="50.0" prefWidth="93.0" promptText="Port" styleClass="text-field" text="3306" />

        <TextField fx:id="txtDbName" layoutX="60.0" layoutY="245.0" prefHeight="50.0" prefWidth="358.0" promptText="Database Name" styleClass="text-field" text="library_system" />

        <TextField fx:id="txtDbUser" layoutX="60.0" layoutY="310.0" prefHeight="50.0" prefWidth="358.0" promptText="MySQL Username" styleClass="text-field" text="root" />

        <PasswordField fx:id="txtDbPass" layoutX="60.0" layoutY="375.0" prefHeight="50.0" prefWidth="358.0" promptText="MySQL Password" styleClass="text-field" />

        <Button layoutX="60.0" layoutY="465.0" onAction="#testAndConnectOnAction" prefHeight="58.0" prefWidth="358.0" styleClass="connect-button" text="CONNECT" />

        <Label fx:id="lblStatus" alignment="CENTER" layoutX="60.0" layoutY="435.0" prefWidth="358.0" textFill="#ef4444" />
    </children>
</AnchorPane>