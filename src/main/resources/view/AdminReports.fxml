<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import java.net.URL?>

<AnchorPane prefHeight="650.0" prefWidth="950.0" styleClass="main-pane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sanda.librarymanagement.controller.AdminReportsController">
    <stylesheets>
        <URL value="@css/style.css" />
    </stylesheets>
    <children>
        <VBox layoutX="30.0" layoutY="30.0" spacing="25.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
            <children>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="report-title" text="System Analytics &amp; Reports">
                                    <font>
                                        <Font name="Segoe UI Bold" size="24.0" />
                                    </font>
                                </Label>
                                <Label styleClass="report-subtitle" text="Visual data summaries and financial reports for the library system." />
                            </children>
                        </VBox>
                        <Button mnemonicParsing="false" onAction="#exportReportOnAction" prefHeight="40.0" prefWidth="160.0" styleClass="export-button" text="Export Full Report" />
                    </children>
                </HBox>

                <HBox spacing="20.0">
                    <children>
                        <VBox prefHeight="100.0" prefWidth="280.0" styleClass="metric-box">
                            <children>
                                <Label styleClass="metric-label" text="Total Revenue (Fines)" />
                                <Region VBox.vgrow="ALWAYS" />
                                <Label fx:id="lblTotalRevenue" styleClass="metric-value-green" text="0.00 LKR">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                        <VBox prefHeight="100.0" prefWidth="280.0" styleClass="metric-box">
                            <children>
                                <Label styleClass="metric-label" text="Outstanding Fines" />
                                <Region VBox.vgrow="ALWAYS" />
                                <Label fx:id="lblOutstandingFines" styleClass="metric-value-red" text="0.00 LKR">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                        <VBox prefHeight="100.0" prefWidth="280.0" styleClass="metric-box">
                            <children>
                                <Label styleClass="metric-label" text="Total Active Rentals" />
                                <Region VBox.vgrow="ALWAYS" />
                                <Label fx:id="lblActiveRentals" styleClass="metric-value-blue" text="0">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <HBox spacing="25.0" VBox.vgrow="ALWAYS">
                    <children>
                        <VBox prefWidth="400.0" spacing="15.0" styleClass="chart-box">
                            <children>
                                <Label styleClass="chart-title" text="Inventory Distribution">
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Label>
                                <PieChart fx:id="chartInventory" legendVisible="true" style="-fx-pie-label-visible: true;" VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>

                        <VBox spacing="15.0" styleClass="chart-box" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="chart-title" text="Most Popular Books">
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Label>
                                <TableView fx:id="tblPopularBooks" prefHeight="200.0" styleClass="table-view" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colRankBookTitle" prefWidth="200.0" text="Book Title" />
                                        <TableColumn fx:id="colRankCategory" prefWidth="120.0" text="Category" />
                                        <TableColumn fx:id="colRankCount" prefWidth="100.0" text="Times Borrowed" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>