<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import java.net.URL?>

<AnchorPane prefHeight="650.0" prefWidth="950.0" styleClass="main-pane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sanda.librarymanagement.controller.UserManagementController">
    <stylesheets>
        <URL value="@css/style.css" />
    </stylesheets>
    <children>
        <VBox layoutX="30.0" layoutY="30.0" spacing="20.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="report-title" text="User Management" />
                                <Label styleClass="report-subtitle" text="Manage staff credentials and access roles." />
                            </children>
                        </VBox>
                        <TextField fx:id="txtSearchUser" prefHeight="40.0" prefWidth="300.0" promptText="Search Username or Role..." styleClass="search-field" />
                    </children>
                </HBox>

                <HBox spacing="25.0" VBox.vgrow="ALWAYS">
                    <children>
                        <VBox prefWidth="320.0" spacing="12.0" styleClass="form-box">
                            <children>
                                <Label styleClass="form-title" text="User Credentials" />
                                <VBox spacing="5.0">
                                    <children>
                                        <Label styleClass="form-label" text="User ID" />
                                        <HBox spacing="8.0" alignment="CENTER_LEFT">
                                            <children>
                                                <TextField fx:id="txtUserId" editable="false" prefHeight="35.0" HBox.hgrow="ALWAYS" styleClass="form-textfield" text="0" />
                                                <Button onAction="#clearIdOnAction" prefHeight="35.0" prefWidth="40.0" styleClass="form-button-green" text="↺" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label styleClass="form-label" text="Username" />
                                        <TextField fx:id="txtUsername" prefHeight="35.0" styleClass="form-textfield" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label styleClass="form-label" text="Password" />
                                        <TextField fx:id="txtPassword" prefHeight="35.0" styleClass="form-textfield" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label styleClass="form-label" text="Role" />
                                        <ComboBox fx:id="cmbRole" maxWidth="Infinity" prefHeight="35.0" promptText="Select Role" styleClass="form-textfield" />
                                    </children>
                                </VBox>

                                <VBox spacing="15.0" style="-fx-padding: 10 0 0 0;">
                                    <children>
                                        <Button fx:id="btnSaveUser" maxWidth="Infinity" onAction="#saveUserOnAction" prefHeight="40.0" styleClass="form-button-purple" text="Create Account" />
                                        <HBox spacing="10.0">
                                            <children>
                                                <Button fx:id="btnUpdateUser" maxWidth="Infinity" onAction="#updateUserOnAction" prefHeight="35.0" styleClass="form-button-green" text="Update" HBox.hgrow="ALWAYS" />
                                                <Button fx:id="btnDeleteUser" maxWidth="Infinity" onAction="#deleteUserOnAction" prefHeight="35.0" styleClass="form-button-red" text="Delete" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <TableView fx:id="tblUsers" prefHeight="200.0" styleClass="table-view" HBox.hgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colUserId" prefWidth="80.0" text="ID" />
                                <TableColumn fx:id="colUsername" prefWidth="200.0" text="Username" />
                                <TableColumn fx:id="colRole" prefWidth="150.0" text="Role" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>